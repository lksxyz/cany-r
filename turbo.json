{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["BETTER_AUTH_URL", "BETTER_AUTH_SECRET", "TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["DATABASE_URL"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
